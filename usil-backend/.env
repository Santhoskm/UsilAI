# ══════════════════════════════════════════════════════
#  DATABASE PASSWORD → change "12345" to YOUR password
#  Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<database>
# ══════════════════════════════════════════════════════
DATABASE_URL=postgresql+asyncpg://postgres:12345@localhost:5432/usil_db

# Claude API Key — get one free at https://console.anthropic.com/
# Replace "your_claude_api_key_here" with your actual key
ANTHROPIC_API_KEY=your_claude_api_key_here

# App settings
DEBUG=true
APP_NAME=Usil AI Backend